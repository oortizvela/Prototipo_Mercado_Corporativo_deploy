        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "requerimientos": {
                "uri": "model/mockdata/requerimientos.json",
                "type": "JSON"
            },
            "aprobaciones": {
                "uri": "model/mockdata/aprobaciones.json",
