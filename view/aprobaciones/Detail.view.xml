<mvc:View
    controllerName="com.claro.compras.portal.controller.aprobaciones.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <uxap:ObjectPageLayout id="objPageApr">

        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:navigationActions>
                    <Button icon="sap-icon://nav-back" type="Transparent" press="onNavBack" tooltip="Volver" />
                </uxap:navigationActions>
                <uxap:heading>
                    <Title text="{aprobaciones>aprId}" level="H2" />
                </uxap:heading>
                <uxap:expandedContent>
                    <ObjectStatus
                        text="{aprobaciones>estado}"
                        state="{= ${aprobaciones>estado} === 'Aprobado' ? 'Success' : ${aprobaciones>estado} === 'Rechazado' ? 'Error' : 'Warning'}"
                        inverted="true" />
                </uxap:expandedContent>
                <uxap:actions>
                    <Button
                        text="Aprobar"
                        type="Emphasized"
                        icon="sap-icon://accept"
                        visible="{= ${aprobaciones>estado} === 'Pendiente'}"
                        press="onApprove" />
                    <Button
                        text="Rechazar"
                        type="Reject"
                        icon="sap-icon://decline"
                        visible="{= ${aprobaciones>estado} === 'Pendiente'}"
                        press="onReject" />
                    <Button
                        text="Reasignar"
                        icon="sap-icon://forward"
                        visible="{= ${aprobaciones>estado} === 'Pendiente'}"
                        press="onReassign" />
                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- KPI Header content -->
        <uxap:headerContent>
            <HBox class="detailHeaderKPIs">
                <VBox class="detailKpiItem">
                    <Label text="Empleado" />
                    <Text text="{aprobaciones>empleado}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem">
                    <Label text="Cargo" />
                    <Text text="{aprobaciones>cargo}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem">
                    <Label text="Área" />
                    <Text text="{aprobaciones>area}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem">
                    <Label text="Fecha Solicitud" />
                    <Text text="{aprobaciones>fechaSolicitud}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem">
                    <Label text="Prioridad" />
                    <ObjectStatus
                        text="{aprobaciones>prioridad}"
                        state="{= ${aprobaciones>prioridad} === 'Alta' ? 'Error' : ${aprobaciones>prioridad} === 'Media' ? 'Warning' : 'None'}" />
                </VBox>
                <!-- KPI Compras Locales -->
                <VBox class="detailKpiItem" visible="{= !${ui>/mercadoCorporativo}}">
                    <Label text="Valor Estimado" />
                    <ObjectNumber
                        number="{path: 'aprobaciones>valorEstimado', type: 'sap.ui.model.type.Float', formatOptions: { minimumFractionDigits: 2 }}"
                        unit="PEN"
                        emphasized="true" />
                </VBox>
                <!-- KPI Mercado Corporativo -->
                <VBox class="detailKpiItem" visible="{ui>/mercadoCorporativo}">
                    <Label text="Cliente" />
                    <Text text="{aprobaciones>cliente}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem" visible="{ui>/mercadoCorporativo}">
                    <Label text="Línea de Negocio" />
                    <Text text="{aprobaciones>lineaNegocio}" class="kpiText" />
                </VBox>
                <VBox class="detailKpiItem" visible="{ui>/mercadoCorporativo}">
                    <Label text="Importe Estimado" />
                    <ObjectNumber
                        number="{path: 'aprobaciones>importeUSD', type: 'sap.ui.model.type.Float', formatOptions: { minimumFractionDigits: 2 }}"
                        unit="USD"
                        emphasized="true"
                        state="{= ${aprobaciones>importeUSD} >= 100000 ? 'Error' : 'None'}" />
                </VBox>
                <VBox class="detailKpiItem" visible="{ui>/mercadoCorporativo}">
                    <Label text="Nivel Actual" />
                    <Text text="{aprobaciones>nivelAprobacion}" class="kpiText" />
                </VBox>
            </HBox>
        </uxap:headerContent>

        <uxap:sections>

        <!-- Section: Datos del Dispositivo (solo Compras Locales) -->
            <uxap:ObjectPageSection title="Datos del Dispositivo Solicitado" visible="{= !${ui>/mercadoCorporativo}}">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection title="">
                        <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                            labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                            columnsXL="2" columnsL="2" columnsM="1">
                            <f:content>
                                <Label text="Tipo de Dispositivo" />
                                <Text text="{aprobaciones>dispositivo}" />
                                <Label text="Marca / Modelo" />
                                <Text text="{aprobaciones>marca} {aprobaciones>modelo}" />
                                <Label text="Almacenamiento" />
                                <Text text="{= ${aprobaciones>almacenamiento} || '—'}" />
                                <Label text="Color" />
                                <Text text="{= ${aprobaciones>color} || '—'}" />
                                <Label text="Cantidad" />
                                <Text text="{aprobaciones>cantidad}" />
                                <Label text="Plan Sugerido" />
                                <Text text="{= ${aprobaciones>planSugerido} || '—'}" />
                                <Label text="Justificación" />
                                <Text text="{aprobaciones>justificacion}" />
                                <Label text="Reemplaza a" />
                                <Text text="{= ${aprobaciones>dispositivoAnterior} || 'No aplica'}" />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- Section: Datos del Proyecto/Servicio (solo Mercado Corporativo) -->
            <uxap:ObjectPageSection title="Datos del Proyecto / Servicio" visible="{ui>/mercadoCorporativo}">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection title="">
                        <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                            labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                            columnsXL="2" columnsL="2" columnsM="1">
                            <f:content>
                                <Label text="Cliente" />
                                <Text text="{aprobaciones>cliente}" />
                                <Label text="Línea de Negocio" />
                                <Text text="{aprobaciones>lineaNegocio}" />
                                <Label text="Área Funcional" />
                                <Text text="{= ${aprobaciones>areaFuncional} || '—'}" />
                                <Label text="Tipo de Requerimiento" />
                                <Text text="{aprobaciones>tipoSolicitud}" />
                                <Label text="Importe Estimado (USD)" />
                                <ObjectNumber
                                    number="{path: 'aprobaciones>importeUSD', type: 'sap.ui.model.type.Float', formatOptions: { minimumFractionDigits: 2 }}"
                                    unit="USD"
                                    state="{= ${aprobaciones>importeUSD} >= 100000 ? 'Error' : 'None'}" />
                                <Label text="ID Oportunidad (Salesforce)" />
                                <Text text="{= ${aprobaciones>oportunidadId} || '—'}" />
                                <Label text="Nivel de Aprobación" />
                                <Text text="{aprobaciones>nivelAprobacion}" />
                                <Label text="Solicitante" />
                                <Text text="{aprobaciones>solicitante}" />
                                <Label text="Cargo Solicitante" />
                                <Text text="{aprobaciones>cargo}" />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- Section: Datos del Empleado -->
            <uxap:ObjectPageSection title="Datos del Empleado">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection title="">
                        <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                            labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                            columnsXL="2" columnsL="2" columnsM="1">
                            <f:content>
                                <Label text="N° Empleado" />
                                <Text text="{= ${aprobaciones>nroEmpleado} || '—'}" />
                                <Label text="Nombre Completo" />
                                <Text text="{aprobaciones>empleado}" />
                                <Label text="Cargo" />
                                <Text text="{aprobaciones>cargo}" />
                                <Label text="Área / Gerencia" />
                                <Text text="{aprobaciones>area}" />
                                <Label text="Sede" />
                                <Text text="{= ${aprobaciones>sede} || '—'}" />
                                <Label text="Correo Corporativo" />
                                <Text text="{= ${aprobaciones>emailEmpleado} || '—'}" />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- Section: Resolución -->
            <uxap:ObjectPageSection title="Resolución">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection title="">
                        <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                            labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                            columnsXL="2" columnsL="2" columnsM="1">
                            <f:content>
                                <Label text="Aprobador" />
                                <Text text="{= ${aprobaciones>aprobador} || 'Pendiente'}" />
                                <Label text="Fecha Aprobación" />
                                <Text text="{= ${aprobaciones>fechaAprobacion} || '—'}" />
                                <Label text="Comentario" />
                                <Text text="{= ${aprobaciones>comentarioAprobador} || '—'}" />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
