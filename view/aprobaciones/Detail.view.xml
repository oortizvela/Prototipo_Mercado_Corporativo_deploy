<mvc:View
    controllerName="com.claro.compras.portal.controller.aprobaciones.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page showHeader="false" enableScrolling="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" type="Transparent" press="onNavBack" tooltip="Volver" />
                    <Title text="{aprobaciones>aprId}" class="reqDetailId" />
                    <ObjectStatus
                        text="{aprobaciones>estado}"
                        state="{= ${aprobaciones>estado} === 'Aprobado Final' ? 'Success' : ${aprobaciones>estado} === 'Aprobado' ? 'Success' : ${aprobaciones>estado} === 'Rechazado' ? 'Error' : 'Warning'}"
                        inverted="true" />
                </contentLeft>
                <contentRight>
                    <Button text="Exportar Excel" icon="sap-icon://excel-attachment" type="Transparent" press="onExportarExcel" />
                    <Button text="Descargar PDF"  icon="sap-icon://pdf-attachment"   type="Transparent" press="onDescargarPDF"  />
                    <Button icon="sap-icon://slim-arrow-left" type="Transparent" press="onToggleHeader" tooltip="Contraer cabecera" />
                </contentRight>
            </Bar>
        </customHeader>

        <!-- HEADER INFO — Handset -->
        <VBox id="aprInfoPanel" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
              visible="{ui>/esHandset}">
            <HBox wrap="Wrap">
                <VBox width="16rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="T&#237;tulo:" design="Bold" />
                    <Text text="{ui>/reqTitulo}" wrapping="false" />
                </VBox>
                <VBox width="18rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Proceso:" design="Bold" />
                    <Text text="{ui>/reqProceso}" wrapping="false" />
                </VBox>
                <VBox width="14rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Creado Por:" design="Bold" />
                    <Text text="{ui>/reqCreadoPor}" />
                </VBox>
                <VBox width="14rem" class="sapUiTinyMarginBottom">
                    <Label text="Fecha de Creaci&#243;n:" design="Bold" />
                    <Text text="{ui>/reqFechaCreacion}" />
                </VBox>
            </HBox>
            <HBox wrap="Wrap">
                <VBox width="16rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Marca:" design="Bold" />
                    <Text text="{ui>/reqMarca}" />
                </VBox>
                <VBox width="18rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Tipo de Solicitud:" design="Bold" />
                    <Text text="{ui>/reqTipoSolicitud}" />
                </VBox>
                <VBox width="14rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="&#218;ltima Modificaci&#243;n:" design="Bold" />
                    <Text text="{ui>/reqUltimaModif}" />
                </VBox>
            </HBox>
            <HBox wrap="Wrap">
                <VBox width="16rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Per&#237;odo:" design="Bold" />
                    <Text text="{ui>/reqPeriodo}" />
                </VBox>
                <VBox width="18rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="V&#225;lido Hasta:" design="Bold" />
                    <Text text="{ui>/reqValidoHasta}" />
                </VBox>
            </HBox>
        </VBox>

        <!-- HEADER INFO — Mercado Corporativo -->
        <VBox id="aprInfoPanelMC" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
              visible="{ui>/esMC}">
            <HBox wrap="Wrap">
                <VBox width="22rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Título" design="Bold" />
                    <Text text="{ui>/reqTitulo}" wrapping="false" />
                </VBox>
                <VBox width="14rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Tipo Inversión" design="Bold" />
                    <Text text="{ui>/reqTipoInversion}" />
                </VBox>
                <VBox width="22rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Tipo de Solicitud" design="Bold" />
                    <Text text="{ui>/reqTipoSolicitud}" />
                </VBox>
                <VBox width="16rem" class="sapUiTinyMarginBottom">
                    <Label text="Origen / Área" design="Bold" />
                    <Text text="{ui>/reqOrigenArea}" />
                </VBox>
            </HBox>
        </VBox>

        <!-- HEADER INFO — otros tipos (sin cambios) -->
        <VBox id="aprInfoPanelOther" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom"
              visible="{= !${ui>/esHandset} &amp;&amp; !${ui>/esMC}}">
            <HBox wrap="Wrap">
                <VBox width="22rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="T&#237;tulo" design="Bold" />
                    <Text text="{aprobaciones>titulo}" wrapping="false" />
                </VBox>
                <VBox width="14rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Canal" design="Bold" />
                    <Text text="{aprobaciones>canal}" />
                </VBox>
                <VBox width="22rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                    <Label text="Tipo de Solicitud" design="Bold" />
                    <Text text="{aprobaciones>tipoSolicitud}" />
                </VBox>
                <VBox width="16rem" class="sapUiTinyMarginBottom">
                    <Label text="L&#237;nea de Negocio" design="Bold" />
                    <Text text="{aprobaciones>lineaNegocio}" />
                </VBox>
            </HBox>
        </VBox>

        <!-- TABS -->
        <IconTabBar id="aprTabs" class="reqDetailTabs" backgroundDesign="Transparent" select="onTabSelect">
            <items>

            <!-- ══ TABS HANDSET ══════════════════════════════════════════════ -->

            <!-- TAB HS-1: PLANIFICACIÓN -->
            <IconTabFilter icon="sap-icon://supplier" text="Planificaci&#243;n" key="hsPlanCompras" visible="{ui>/esHandset}">
                <content>
                    <VBox class="reqTabSection">
                        <Title text="&#205;tems de Planificaci&#243;n" level="H4" class="reqSectionTitle" />
                        <ScrollContainer horizontal="true" vertical="false" width="100%">
                            <Table id="hsPlanTable" items="{aprobaciones>planCompras/items}" fixedLayout="false"
                                   noDataText="Sin &#237;tems de planificaci&#243;n." class="reqItemsTable">
                                <columns>
                                    <Column><Text text="Modelo" /></Column>
                                    <Column><Text text="C&#243;digo" /></Column>
                                    <Column><Text text="C&#243;d. Material" /></Column>
                                    <Column><Text text="Color" /></Column>
                                    <Column hAlign="End"><Text text="Cantidad" /></Column>
                                    <Column hAlign="End"><Text text="Precio Fact. US$" /></Column>
                                    <Column hAlign="End"><Text text="VIR Unit. US$" /></Column>
                                    <Column hAlign="End"><Text text="Precio Neto US$" /></Column>
                                    <Column hAlign="End"><Text text="Total Fact. US$" /></Column>
                                    <Column hAlign="End"><Text text="Total VIR US$" /></Column>
                                    <Column hAlign="End"><Text text="Total Neto US$" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{aprobaciones>modelo}" />
                                            <Text text="{aprobaciones>codigo}" />
                                            <Text text="{aprobaciones>codigoMaterial}" />
                                            <Text text="{aprobaciones>color}" />
                                            <Text text="{aprobaciones>cantidad}" textAlign="End" />
                                            <Text text="{aprobaciones>precioFact}" textAlign="End" />
                                            <Text text="{aprobaciones>virFact}" textAlign="End" />
                                            <Text text="{aprobaciones>precioNeto}" textAlign="End" />
                                            <Text text="{aprobaciones>totalFact}" textAlign="End" />
                                            <Text text="{aprobaciones>totalVIR}" textAlign="End" />
                                            <Text text="{aprobaciones>totalNeto}" textAlign="End" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </ScrollContainer>

                        <!-- APORTES -->
                        <Title text="APORTES US$" level="H5" class="reqSectionTitle sapUiMediumMarginTop" />
                        <HBox class="sapUiSmallMarginBottom">
                            <Label text="VIR:" class="sapUiSmallMarginEnd" />
                            <Text text="{aprobaciones>planCompras/aportes/vir}" />
                        </HBox>
                        <Table id="hsAportesTable" items="{aprobaciones>planCompras/aportes/otros}"
                               fixedLayout="false" noDataText="" showSeparators="None">
                            <columns>
                                <Column><Text text="" /></Column>
                                <Column hAlign="End" width="8rem"><Text text="Monto US$" /></Column>
                                <Column hAlign="End" width="6rem"><Text text="%" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{aprobaciones>concepto}" />
                                        <Text text="{aprobaciones>monto}" />
                                        <Text text="{aprobaciones>porcentaje}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Líneas de firma -->
                        <HBox justifyContent="SpaceBetween" class="sapUiLargeMarginTop" wrap="Wrap">
                            <VBox alignItems="Center" width="30%" class="sapUiSmallMarginEnd">
                                <HBox height="2px" width="100%" class="aprSignLine" />
                                <Text text="{aprobaciones>aprobadores/0/nombre}" class="sapUiTinyMarginTop" />
                                <Text text="{aprobaciones>aprobadores/0/rol}" />
                            </VBox>
                            <VBox alignItems="Center" width="30%" class="sapUiSmallMarginEnd">
                                <HBox height="2px" width="100%" class="aprSignLine" />
                                <Text text="{aprobaciones>aprobadores/1/nombre}" class="sapUiTinyMarginTop" />
                                <Text text="{aprobaciones>aprobadores/1/rol}" />
                            </VBox>
                            <VBox alignItems="Center" width="30%">
                                <HBox height="2px" width="100%" class="aprSignLine" />
                                <Text text="{aprobaciones>aprobadores/2/nombre}" class="sapUiTinyMarginTop" />
                                <Text text="{aprobaciones>aprobadores/2/rol}" />
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </IconTabFilter>

            <!-- TAB HS-2: FLUJO DE APROBACIÓN -->
            <IconTabFilter icon="sap-icon://checklist-2" text="Flujo de Apr..." key="hsFlujo" visible="{ui>/esHandset}">
                <content>
                    <VBox class="reqTabSection">
                        <Title text="Pasos de Aprobaci&#243;n" level="H4" class="reqSectionTitle" />
                        <!-- Diagrama de flujo (mismo formato que Detail requerimiento) -->
                        <HBox id="aprFlowDiagram" class="reqApprovalFlow" alignItems="Start" />
                        <!-- Tarjetas de personas -->
                        <HBox id="aprFlowCards" class="reqApprovalCards" wrap="Wrap" />
                    </VBox>
                </content>
            </IconTabFilter>

            <!-- TAB HS-3: ADJUNTOS -->
            <IconTabFilter icon="sap-icon://attachment" text="Adjuntos" key="hsAdjuntos" visible="{ui>/esHandset}">
                <content>
                    <VBox class="reqTabSection">
                        <!-- Sub-sección 1: Acuerdos con proveedor -->
                        <Title text="Acuerdos con Proveedor" level="H5" class="reqSectionTitle" />
                        <Text text="Formatos aceptados: .eml, .msg" class="sapUiTinyMarginBottom" style="font-size:0.78rem;color:#6a7480" />
                        <Table id="hsAdjAcuerdos" items="{aprobaciones>adjuntos/acuerdos}"
                               noDataText="Sin acuerdos adjuntos." showSeparators="Inner">
                            <columns>
                                <Column><Text text="Nombre" /></Column>
                                <Column width="6rem"><Text text="Tipo" /></Column>
                                <Column width="13rem"><Text text="Fecha" /></Column>
                                <Column><Text text="Cargado por" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://email" color="#1565c0" class="sapUiSmallMarginEnd" />
                                            <Text text="{aprobaciones>nombre}" />
                                        </HBox>
                                        <Text text="{aprobaciones>tipo}" />
                                        <Text text="{aprobaciones>fecha}" />
                                        <Text text="{aprobaciones>cargadoPor}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Sub-sección 2: Otros archivos -->
                        <Title text="Otros Archivos" level="H5" class="reqSectionTitle sapUiMediumMarginTop" />
                        <Text text="Formatos aceptados: .doc, .docx" class="sapUiTinyMarginBottom" style="font-size:0.78rem;color:#6a7480" />
                        <Table id="hsAdjOtros" items="{aprobaciones>adjuntos/otrosArchivos}"
                               noDataText="Sin archivos adjuntos." showSeparators="Inner">
                            <columns>
                                <Column><Text text="Nombre" /></Column>
                                <Column width="6rem"><Text text="Tipo" /></Column>
                                <Column width="13rem"><Text text="Fecha" /></Column>
                                <Column><Text text="Cargado por" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://document-text" color="#1565c0" class="sapUiSmallMarginEnd" />
                                            <Text text="{aprobaciones>nombre}" />
                                        </HBox>
                                        <Text text="{aprobaciones>tipo}" />
                                        <Text text="{aprobaciones>fecha}" />
                                        <Text text="{aprobaciones>cargadoPor}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </content>
            </IconTabFilter>

            <!-- TAB HS-4: ACTA DE ACEPTACIÓN (solo Director de Finanzas) -->
            <IconTabFilter
                icon="sap-icon://pdf-attachment"
                text="Acta de Aceptaci&#xF3;n"
                key="hsActa"
                visible="{ui>/esDirFinanzas}">
                <content>
                    <VBox class="reqTabSection">
                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                            <Title text="Acta de Aceptaci&#xF3;n" level="H4" class="reqSectionTitle" />
                            <ObjectStatus
                                text="{aprobaciones>actaAceptacion/estadoDocuSign}"
                                icon="{= ${aprobaciones>actaAceptacion/estadoDocuSign} === 'Firmado' ? 'sap-icon://sys-enter-2' : 'sap-icon://pending'}"
                                state="{= ${aprobaciones>actaAceptacion/estadoDocuSign} === 'Firmado' ? 'Success' : 'Warning'}"
                                visible="{= !!${aprobaciones>actaAceptacion/estadoDocuSign}}" />
                        </HBox>

                        <VBox class="actaDocPreview sapUiMediumMarginBeginEnd">
                            <!-- Cabecera -->
                            <HBox justifyContent="SpaceBetween" alignItems="Start" class="actaDocHeader">
                                <VBox>
                                    <core:Icon src="sap-icon://business-objects-experience" size="3rem" color="#cc0000" class="sapUiSmallMarginBottom" />
                                </VBox>
                                <VBox alignItems="End">
                                    <Text text="Am&#xE9;rica M&#xF3;vil Per&#xFA; S.A.C." class="actaDocEmpresa" />
                                    <Text text="Av. Nicol&#xE1;s Arriola 480, Santa Catalina" class="actaDocDireccion" />
                                    <Text text="La Victoria, Lima, Per&#xFA;" class="actaDocDireccion" />
                                    <Text text="Tel&#xE9;fono: +51 1 613-1000" class="actaDocDireccion" />
                                    <Link text="www.claro.com.pe" class="actaDocDireccion" />
                                </VBox>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" class="actaDocSubHeader">
                                <Text text="{aprobaciones>actaAceptacion/fechaDocumento}" class="actaDocFecha" />
                                <Text text="{aprobaciones>actaAceptacion/numeroActa}" class="actaDocNumero" />
                            </HBox>

                            <VBox class="actaDocDestinatario">
                                <Text text="Se&#xF1;ores:" class="actaDocLabel" />
                                <Text text="{aprobaciones>actaAceptacion/proveedor}" class="actaDocProvNombre" />
                            </VBox>
                            <HBox class="actaDocCampo">
                                <Label text="Atenci&#xF3;n   :" width="9rem" design="Bold" />
                                <Text text="{aprobaciones>actaAceptacion/contacto}" />
                            </HBox>
                            <HBox class="actaDocCampo sapUiTinyMarginTop">
                                <Label text="Asunto       :" width="9rem" design="Bold" />
                                <Text text="{aprobaciones>actaAceptacion/asunto}" />
                            </HBox>

                            <VBox class="actaDocCuerpo">
                                <Text
                                    text="Por medio de la presente confirmamos la adquisici&#xF3;n de los siguientes equipos a {aprobaciones>actaAceptacion/proveedor}:"
                                    wrapping="true"
                                    class="actaDocTexto" />
                            </VBox>

                            <!-- Tabla de ítems -->
                            <ScrollContainer horizontal="true" vertical="false" width="100%">
                                <Table
                                    items="{aprobaciones>actaAceptacion/items}"
                                    fixedLayout="false"
                                    noDataText="Sin &#237;tems."
                                    class="actaItemsTable">
                                    <columns>
                                        <Column><Text text="Modelo" /></Column>
                                        <Column width="9rem"><Text text="Color" /></Column>
                                        <Column width="7rem" hAlign="End"><Text text="Cantidad" /></Column>
                                        <Column width="12rem" hAlign="End"><Text text="Precio Facturaci&#xF3;n US$" /></Column>
                                        <Column width="12rem" hAlign="End"><Text text="Total US$" /></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <Text text="{aprobaciones>modelo}" wrapping="false" />
                                                <Text text="{aprobaciones>color}" />
                                                <Text text="{aprobaciones>cantidad}" textAlign="End" />
                                                <Text text="{aprobaciones>precioFact}" textAlign="End" />
                                                <Text text="{aprobaciones>totalFact}" textAlign="End" />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>

                            <Text
                                text="Los precios aplicables no ser&#xE1;n mayores a los aprobados para el grupo Am&#xE9;rica M&#xF3;vil. Se aplicar&#xE1; protecci&#xF3;n de precios en base a los precios negociados para la regi&#xF3;n."
                                wrapping="true"
                                class="actaDocTexto actaDocClausula" />

                            <!-- Firmas -->
                            <HBox justifyContent="SpaceBetween" class="actaDocFirmas">
                                <VBox alignItems="Center" width="45%">
                                    <VBox class="actaFirmaLinea" />
                                    <Text text="Firma Proveedor" class="actaFirmaLabel" />
                                    <Text text="{aprobaciones>actaAceptacion/proveedor}" class="actaFirmaSubLabel" />
                                </VBox>
                                <VBox alignItems="Center" width="45%">
                                    <VBox class="actaFirmaLinea" />
                                    <Text text="Director de Finanzas" class="actaFirmaLabel" />
                                    <Text text="Am&#xE9;rica M&#xF3;vil Per&#xFA; S.A.C." class="actaFirmaSubLabel" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <Button
                            text="Descargar PDF"
                            icon="sap-icon://download"
                            type="Transparent"
                            press="onDescargarActaPDF"
                            class="sapUiSmallMarginTop sapUiSmallMarginBegin" />
                    </VBox>
                </content>
            </IconTabFilter>

            <!-- MERCADO CORPORATIVO -->
            <IconTabFilter icon="sap-icon://money-bills" text="Costos &amp; Ingresos" key="mcCostos" visible="{ui>/esMC}">
                <content><VBox class="reqTabSection">
                    <Title text="Costos e Ingresos del Proyecto" level="H4" class="reqSectionTitle" />
                    <Table items="{ui>/mcCostos}" fixedLayout="false" noDataText="Sin datos." class="reqItemsTable">
                        <columns>
                            <Column width="12rem"><Text text="Tipo" /></Column>
                            <Column><Text text="Descripci&#243;n" /></Column>
                            <Column width="12rem" hAlign="End"><Text text="Monto (US$)" /></Column>
                        </columns>
                        <items><ColumnListItem><cells>
                            <Text text="{ui>tipo}" />
                            <Text text="{ui>descripcion}" />
                            <Text text="{ui>monto}" />
                        </cells></ColumnListItem></items>
                    </Table>
                </VBox></content>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://bar-chart" text="KPI's" key="mcKpis" visible="{ui>/esMC}">
                <content><VBox class="reqTabSection">
                    <Title text="Indicadores de Rentabilidad" level="H4" class="reqSectionTitle" />
                    <Table items="{ui>/mcKpis}" fixedLayout="false" noDataText="Sin KPIs." class="reqItemsTable">
                        <columns>
                            <Column><Text text="KPI" /></Column>
                            <Column width="12rem" hAlign="End"><Text text="Valor" /></Column>
                        </columns>
                        <items><ColumnListItem><cells>
                            <Text text="{ui>kpi}" />
                            <Text text="{ui>valor}" />
                        </cells></ColumnListItem></items>
                    </Table>
                </VBox></content>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://document-text" text="Presentaci&#243;n Cliente" key="mcPresentacion" visible="{ui>/esMC}">
                <content><VBox class="reqTabSection">
                    <Title text="Presentaci&#243;n al Cliente" level="H4" class="reqSectionTitle" />
                    <FormattedText htmlText="{ui>/mcPresentacion}" class="aprPresentacionContent" />
                </VBox></content>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://checklist-2" text="Flujo de Aprobaci&#243;n" key="mcFlujo" visible="{ui>/esMC}">
                <content><VBox class="reqTabSection">
                    <Title text="Cadena de Aprobaci&#243;n &#8211; Mercado Corporativo" level="H4" class="reqSectionTitle" />
                    <HBox id="mcFlowDiagram" class="reqApprovalFlow" alignItems="Start" />
                    <HBox id="mcFlowCards"   class="reqApprovalCards" wrap="Wrap" />
                </VBox></content>
            </IconTabFilter>

            <!-- RED MOVIL -->
            <IconTabFilter icon="sap-icon://supplier" text="Planificaci&#243;n" key="rmPlan" visible="{ui>/esRedMovil}">
                <content><VBox class="reqTabSection">
                    <Title text="&#205;tems de Planificaci&#243;n &#8211; Red M&#243;vil" level="H4" class="reqSectionTitle" />
                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                        <Table items="{aprobaciones>items}" fixedLayout="false" noDataText="Sin &#237;tems." class="reqItemsTable">
                            <columns>
                                <Column width="3rem" hAlign="Center"><Text text="N&#176;" /></Column>
                                <Column width="9rem"><Text text="Tipo &#205;tem" /></Column>
                                <Column width="18rem"><Text text="Descripci&#243;n" /></Column>
                                <Column width="10rem"><Text text="Tecnolog&#237;a" /></Column>
                                <Column width="9rem"><Text text="Banda" /></Column>
                                <Column width="7rem" hAlign="End"><Text text="Cantidad" /></Column>
                                <Column width="9rem"><Text text="Tipo Sitio" /></Column>
                                <Column width="10rem"><Text text="Ubicaci&#243;n" /></Column>
                                <Column width="12rem"><Text text="Proveedor" /></Column>
                                <Column width="15rem"><Text text="Observaci&#243;n" /></Column>
                            </columns>
                            <items><ColumnListItem><cells>
                                <Text text="{aprobaciones>no}" />
                                <Text text="{aprobaciones>tipoItem}" />
                                <Text text="{aprobaciones>descripcion}" />
                                <Text text="{aprobaciones>tecnologia}" />
                                <Text text="{aprobaciones>banda}" />
                                <Text text="{aprobaciones>cantidad}" />
                                <Text text="{aprobaciones>tipoSitio}" />
                                <Text text="{aprobaciones>ubicacion}" />
                                <Text text="{aprobaciones>proveedor}" />
                                <Text text="{aprobaciones>observacion}" />
                            </cells></ColumnListItem></items>
                        </Table>
                    </ScrollContainer>
                </VBox></content>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://checklist-2" text="Flujo de Aprobaci&#243;n" key="rmFlujo" visible="{ui>/esRedMovil}">
                <content><VBox class="reqTabSection">
                    <Title text="Cadena de Aprobaci&#243;n &#8211; Red M&#243;vil" level="H4" class="reqSectionTitle" />
                    <Table items="{aprobaciones>aprobadores}" fixedLayout="false" noDataText="Sin cadena definida.">
                        <columns>
                            <Column width="5rem" hAlign="Center"><Text text="Nivel" /></Column>
                            <Column><Text text="Rol" /></Column>
                            <Column width="12rem"><Text text="Nombre" /></Column>
                            <Column width="9rem" hAlign="Center"><Text text="Estado" /></Column>
                        </columns>
