                <Button id="btnShellAppTitle"
                        text="Home"
                        icon="sap-icon://slim-arrow-down"
                        iconFirst="false"
                        type="Transparent"
                        class="shellNavHomeBtn" />
            </HBox>

            <!-- Derecha: Iconos utilitarios + Avatar -->
            <HBox alignItems="Center" class="shellIconsBox">
                <Button icon="sap-icon://search" type="Transparent" class="shellHeaderIcon" tooltip="Buscar" />
                <Button icon="sap-icon://world"  type="Transparent" class="shellHeaderIcon" tooltip="Idioma" />
                <Avatar initials="OO" displaySize="XS" class="shellAvatar" press="onAvatarPress" />
            </HBox>

        </HBox>

        <!-- NavContainer â€” target del router -->
