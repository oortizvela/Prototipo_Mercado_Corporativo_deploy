                <core:HTML content="&lt;div class='sapLogoSquare' id='sapLogoClickable' style='cursor:pointer'&gt;&lt;span&gt;SAP&lt;/span&gt;&lt;/div&gt;" />
                <Text text="Build Work Zone" class="shellBrandTitle" />
            </HBox>

            <!-- Centro: TÃ­tulo de la aplicaciÃ³n activa -->
