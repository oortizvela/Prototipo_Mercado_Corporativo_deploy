<mvc:View
    controllerName="com.claro.compras.portal.controller.mantenimiento.LineasNegocio"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        title="Líneas de Negocio – Mercado Corporativo"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="appPage">

        <headerContent>
            <Button text="+ Agregar Línea" type="Emphasized" press="onAddLinea"/>
            <Button icon="sap-icon://refresh" type="Transparent" press="onRefresh" tooltip="Actualizar"/>
        </headerContent>

        <content>
            <Panel id="panelLineas" expandable="true" expanded="true" class="mtnListPanel">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Líneas de Negocio ({= (${lineasNegocio>/lineasNegocio} || []).length})" level="H5"/>
                        <ToolbarSpacer/>
                        <SearchField
                            id="searchLinea"
                            placeholder="Buscar línea..."
                            width="16rem"
                            search="onSearchLinea"
                            liveChange="onSearchLinea"/>
                    </OverflowToolbar>
                </headerToolbar>

                <Table
                    id="tableLineas"
                    items="{lineasNegocio>/lineasNegocio}"
                    noDataText="No se encontraron líneas de negocio"
                    growing="true"
                    growingThreshold="10">
                    <columns>
                        <Column><Text text="Línea de Negocio"/></Column>
                        <Column width="14rem"><Text text="Tipo de Solicitud"/></Column>
                        <Column width="8rem" hAlign="Center"><Text text="Nº Áreas"/></Column>
                        <Column width="7rem" hAlign="Center"><Text text="Estado"/></Column>
                        <Column width="10rem" hAlign="Center"><Text text="Acciones"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onLineaRowPress">
                            <cells>
                                <Link text="{lineasNegocio>text}" press="onLineaRowPress" class="mtnCodeLink"/>
                                <Text text="{= ${lineasNegocio>tipoSolicitud} === 'both' ? 'Continuidad y Proyectos/RFP' : ${lineasNegocio>tipoSolicitud}}"/>
                                <ObjectNumber number="{= (${lineasNegocio>areasFunc} || []).length}" unit="áreas"/>
                                <ObjectStatus
                                    text="{= ${lineasNegocio>estado} !== false ? 'Activa' : 'Inactiva'}"
                                    state="{= ${lineasNegocio>estado} !== false ? 'Success' : 'Error'}"/>
                                <HBox justifyContent="Center">
                                    <Button icon="sap-icon://detail-view" type="Transparent" tooltip="Ver áreas" press="onVerAreas"/>
                                    <Button icon="sap-icon://edit" type="Transparent" tooltip="Editar" press="onEditLinea"/>
                                    <Button icon="sap-icon://delete" type="Transparent" tooltip="Eliminar" press="onDeleteLinea"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </content>

        <!-- Dialog Ver Áreas Funcionales -->
        <Dialog id="dlgAreas" title="Áreas Funcionales" contentWidth="680px" resizable="true">
            <content>
                <VBox class="mtnDlgContent">
                    <Title id="dlgAreasTitle" text="" level="H4" class="sapUiSmallMarginBottom"/>
                    <Table
                        id="tableAreas"
                        noDataText="Sin áreas configuradas"
                        class="sapUiSmallMarginTop">
                        <columns>
                            <Column><Text text="Área Funcional"/></Column>
                            <Column width="16rem"><Text text="Segmento"/></Column>
                            <Column width="12rem"><Text text="Responsable"/></Column>
                        </columns>
                    </Table>
                </VBox>
            </content>
            <buttons>
                <Button text="Cerrar" press="onCloseAreas"/>
            </buttons>
        </Dialog>

    </Page>
</mvc:View>
