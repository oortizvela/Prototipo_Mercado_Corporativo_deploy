<mvc:View
    controllerName="com.claro.compras.portal.controller.mantenimiento.NivelesAprobacion"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        title="Niveles de AprobaciÃ³n"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="appPage">

        <headerContent>
            <Button text="+ Agregar Nuevo" type="Emphasized" press="onAddNivel"/>
            <Button icon="sap-icon://refresh" type="Transparent" press="onRefresh" tooltip="Actualizar"/>
        </headerContent>

        <content>
            <Panel id="panelNiveles" expandable="true" expanded="true" class="mtnListPanel">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Elementos ({= (${mantenimiento>/nivelesAprobacion} || []).length})" level="H5"/>
                    </OverflowToolbar>
                </headerToolbar>

                <Table
                    id="tableNiveles"
                    items="{mantenimiento>/nivelesAprobacion}"
                    noDataText="No se encontraron registros"
                    growing="true"
                    growingThreshold="10">
                    <columns>
                        <Column width="4rem" hAlign="Center"><Text text="Nivel"/></Column>
                        <Column width="10rem"><Text text="Flujo"/></Column>
                        <Column><Text text="DescripciÃ³n"/></Column>
                        <Column width="14rem"><Text text="Tipo Aprobador"/></Column>
                        <Column width="12rem"><Text text="Tipos Solicitud"/></Column>
                        <Column width="5rem" hAlign="Center"><Text text="Orden"/></Column>
                        <Column width="7rem"><Text text="Estado"/></Column>
                        <Column width="9rem" hAlign="Center"><Text text="Acciones"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onNivelRowPress">
                            <cells>
                                <Link text="{mantenimiento>nivel}" press="onNivelRowPress" class="mtnCodeLink"/>
                                <Text text="{mantenimiento>flujo}"/>
                                <Text text="{mantenimiento>descripcion}"/>
                                <VBox>
                                    <Text text="{mantenimiento>tipoAprobador}"/>
                                    <Text text="{= ${mantenimiento>tipoAprobador} === 'Constante' ? 'Constante: ' + ${mantenimiento>constanteAprobadora} : ${mantenimiento>nombreGrupoIAS} ? 'Grupo: ' + ${mantenimiento>nombreGrupoIAS} : ''}" class="secondaryText"/>
                                </VBox>
                                <Text text="{mantenimiento>tiposSolicitud}"/>
                                <Text text="{mantenimiento>orden}" textAlign="Center"/>
                                <ObjectStatus
                                    text="{= ${mantenimiento>estado} ? 'Activo' : 'Inactivo'}"
                                    state="{= ${mantenimiento>estado} ? 'Success' : 'Error'}"/>
                                <HBox>
                                    <Button icon="sap-icon://edit"   type="Transparent" tooltip="Editar"   press="onEditNivel"/>
                                    <Button icon="sap-icon://delete" type="Transparent" tooltip="Eliminar" press="onDeleteNivel"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </content>
    </Page>
</mvc:View>
