<mvc:View
    controllerName="com.claro.compras.portal.controller.mantenimiento.ClientesMC"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        title="Clientes â€“ Mercado Corporativo"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="appPage">

        <content>
            <VBox class="mtnPageContent">

                <Table
                    id="clientesTable"
                    items="{clientesMC>/clientes}"
                    noDataText="Sin clientes registrados."
                    class="mtnTable">

                    <headerToolbar>
                        <OverflowToolbar>
                            <SearchField
                                id="searchCliente"
                                placeholder="Buscar cliente..."
                                liveChange="onSearchCliente"
                                width="18rem" />
                            <ToolbarSpacer />
                            <Button
                                text="+ Agregar Cliente"
                                type="Emphasized"
                                press="onAddCliente" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column><Text text="Cliente / Empresa" /></Column>
                        <Column width="10rem"><Text text="RUC" /></Column>
                        <Column width="14rem"><Text text="Sector" /></Column>
                        <Column width="8rem" hAlign="Center"><Text text="Estado" /></Column>
                        <Column width="10rem" hAlign="Center"><Text text="Acciones" /></Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{clientesMC>text}" wrapping="false" />
                                <Text text="{clientesMC>ruc}" />
                                <Text text="{clientesMC>sector}" />
                                <ObjectStatus
                                    text="{clientesMC>estado}"
                                    state="{= ${clientesMC>estado} === 'Activo' ? 'Success' : 'Error'}" />
                                <HBox justifyContent="Center">
                                    <Button icon="sap-icon://edit"   type="Transparent" tooltip="Editar"   press="onEditCliente" />
                                    <Button icon="sap-icon://delete" type="Transparent" tooltip="Eliminar" press="onDeleteCliente" />
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

            </VBox>
        </content>
    </Page>
</mvc:View>
