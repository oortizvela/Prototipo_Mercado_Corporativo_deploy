<mvc:View
    controllerName="com.claro.compras.portal.controller.Portal"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <!--
        showHeader="false" â€” dibujamos nuestro propio shell
        dentro del content para tener control total del estilo.
    -->
    <Page showHeader="false" class="portalPage" enableScrolling="true">
        <content>

            <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                 CONTENT AREA
                 â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
            <VBox class="portalContentArea">

                <VBox class="portalSection">
                    <Title text="Compras" level="H2" class="portalSectionTitle" />

                    <HBox wrap="Wrap" class="portalTilesRow">

                        <!-- Tile 1: Gestión Requerimientos Compras – Solicitante y Administrador -->
                        <GenericTile
                            id="tileRequerimiento"
                            header="Gestión Requerimientos Compras"
                            subheader="Solicitudes"
                            press="onTileRequerimiento"
                            class="portalTile"
                            frameType="OneByOne"
                            visible="{= ${session>/categoria} === 'Solicitante' || ${session>/categoria} === 'Administrador' }">
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <ImageContent src="sap-icon://receipt" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <!-- Tile 2: Bandeja de Aprobación – Aprobador y Administrador -->
                        <GenericTile
                            id="tileAprobaciones"
                            header="Bandeja de Aprobación"
                            subheader="Solicitudes pendientes"
                            press="onTileAprobaciones"
                            class="portalTile"
                            frameType="OneByOne"
                            visible="{= ${session>/categoria} === 'Aprobador' || ${session>/categoria} === 'Administrador' }">
                            <tileContent>
                                <TileContent footer="pendientes">
                                    <content>
                                        <NumericContent
                                            value="{portal>/pendientes}"
                                            withMargin="false"
                                            valueColor="Critical" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <!-- Tile 3: Mantenimiento de Datos – Administrador únicamente -->
                        <GenericTile
                            id="tileMantenimiento"
                            header="Mantenimiento de Datos"
                            press="onTileMantenimiento"
                            class="portalTile"
                            frameType="OneByOne"
                            visible="{= ${session>/categoria} === 'Administrador' }">
                        </GenericTile>

                        <!-- Tile 4: Compras Handsets – solo rol Compras -->
                        <GenericTile
                            id="tileComprasHandsets"
                            header="Compras Handsets"
                            subheader="Solicitudes pendientes aprobaci&#243;n"
                            press="onTileComprasHandsets"
                            class="portalTile"
                            frameType="OneByOne"
                            visible="{= ${session>/rol} === 'Compras' }">
                            <tileContent>
                                <TileContent footer="pendientes">
                                    <content>
                                        <NumericContent
                                            value="{portal>/pendientesCompras}"
                                            withMargin="false"
                                            valueColor="Critical" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                    </HBox>
                </VBox>



            </VBox>

        </content>
    </Page>
</mvc:View>
