<mvc:View
    controllerName="com.claro.compras.portal.controller.requerimiento.InfraMCList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page showHeader="false" enableScrolling="false">
        <content>

            <!-- Título principal -->
            <VBox class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">
                <Title text="Gestión de Solicitud de Requerimientos de Compras"
                       level="H2" />
            </VBox>

            <!-- Barra de filtros (2.2.3) -->
            <Panel expandable="false" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <content>
                    <HBox wrap="Wrap" alignItems="End" class="sapUiSmallMargin">
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Número de Solicitud" labelFor="iFilterNumSol" />
                            <Input id="iFilterNumSol" liveChange="onFilterChange" width="11rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Título" labelFor="iFilterTitulo" />
                            <Input id="iFilterTitulo" liveChange="onFilterChange" width="14rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Estado" labelFor="sFilterEstado" />
                            <Select id="sFilterEstado" change="onFilterChange" width="14rem">
                                <core:Item key="" text="" />
                                <core:Item key="Registrado"      text="Registrado" />
                                <core:Item key="En Aprobación"   text="En Aprobación" />
                                <core:Item key="Aprobado"        text="Aprobado" />
                                <core:Item key="Rechazado"       text="Rechazado" />
                                <core:Item key="Finalizado"      text="Finalizado" />
                            </Select>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="N° Solped" labelFor="iFilterSolped" />
                            <Input id="iFilterSolped" liveChange="onFilterChange" width="10rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="N° Pedido" labelFor="iFilterPedido" />
                            <Input id="iFilterPedido" liveChange="onFilterChange" width="10rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Tipo Solicitud" labelFor="sFilterTipo" />
                            <Select id="sFilterTipo" change="onFilterChange" width="20rem">
                                <core:Item key="" text="" />
                                <core:Item key="Proyectos - Soluciones Medida"     text="Proyectos - Soluciones Medida" />
                                <core:Item key="Proyectos - Compras Recurrentes"   text="Proyectos - Compras Recurrentes" />
                            </Select>
                        </VBox>
                        <Link text="Limpiar Filtros" press="onClearFilters" class="sapUiSmallMarginBegin" />
                    </HBox>
                </content>
            </Panel>

            <!-- Tabla de solicitudes (2.2.1) -->
            <Table
                id="infraTable"
                items="{infraMC>/items}"
                growing="true"
                growingThreshold="20"
                noDataText="No se encontraron solicitudes"
                mode="MultiSelect"
                selectionChange="onSelectionChange"
                class="sapUiSmallMarginBeginEnd">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Solicitudes" level="H3" />
                        <ToolbarSpacer />
                        <Button text="+ Crear Solicitud"
                                type="Emphasized"
                                press="onCrearSolicitud" />
                        <Button text="Factibilidad"
                                icon="sap-icon://decision"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onFactibilidad" />
                        <Button text="Análisis Financiero"
                                icon="sap-icon://money-bills"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onAnalisisFinanciero" />
                        <Button text="Aprob. Necesidad"
                                icon="sap-icon://approvals"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onAprobNecesidad" />
                        <Button text="Aprob. Cliente"
                                icon="sap-icon://customer-and-contacts"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onAprobCliente" />
                        <Button text="Finalizar Solicitud"
                                icon="sap-icon://task"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onFinalizar" />
                        <Button text="Exportar Excel"
                                icon="sap-icon://excel-attachment"
                                type="Transparent"
                                press="onExportar" />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="13rem"><Text text="Número de Solicitud" /></Column>
                    <Column><Text text="Título" /></Column>
                    <Column width="16rem"><Text text="Tipo de Solicitud" /></Column>
                    <Column width="14rem"><Text text="Estado" /></Column>
                    <Column width="10rem"><Text text="N° Solped" /></Column>
                    <Column width="10rem"><Text text="N° Pedido" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Link text="{infraMC>reqId}" press="onItemPress" />
                            <Text text="{infraMC>titulo}" wrapping="false" />
                            <Text text="{infraMC>tipoSolicitud}" />
                            <ObjectStatus
                                text="{infraMC>estado}"
                                icon="{= ${infraMC>estado} === 'Rechazado'     ? 'sap-icon://sys-cancel-2'  :
                                          ${infraMC>estado} === 'Finalizado'   ? 'sap-icon://sys-enter-2'   :
                                          ${infraMC>estado} === 'Aprobado'     ? 'sap-icon://sys-enter-2'   :
                                          ${infraMC>estado} === 'En Aprobación'? 'sap-icon://sys-help-2'    :
                                          ${infraMC>estado} === 'Registrado'   ? 'sap-icon://create-form'   :
                                                                                  'sap-icon://sys-help-2'}"
                                state="{= ${infraMC>estado} === 'Rechazado'     ? 'Error'   :
                                          ${infraMC>estado} === 'Finalizado'    ? 'Success' :
                                          ${infraMC>estado} === 'Aprobado'      ? 'Success' :
                                          ${infraMC>estado} === 'En Aprobación' ? 'Warning' :
                                                                                   'None'}" />
                            <Text text="{infraMC>numeroSolped}" />
                            <Text text="{infraMC>numeroPedido}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

        </content>
    </Page>

    <!-- Diálogo Crear Solicitud Infra MC (2.2.2) -->
    <Dialog
        id="dlgCrearInfra"
        title="Crear Solicitud"
        contentWidth="36rem"
        verticalScrolling="false"
        stretch="false"
        class="sapUiContentPadding">
        <content>
            <VBox width="100%">
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="Título:" required="true" labelFor="dlgInfraTitulo" />
                    <Input id="dlgInfraTitulo"
                           placeholder="Ingrese el título de la solicitud"
                           width="100%" />
                </VBox>
                <VBox>
                    <Label text="Tipo de Solicitud:" required="true" labelFor="dlgInfraTipo" />
                    <Select id="dlgInfraTipo" width="100%">
                        <core:Item key="Proyectos - Soluciones Medida"   text="Proyectos - Soluciones Medida" />
                        <core:Item key="Proyectos - Compras Recurrentes" text="Proyectos - Compras Recurrentes" />
                    </Select>
                </VBox>
            </VBox>
        </content>
        <buttons>
            <Button text="Crear"    type="Emphasized" press="onConfirmCrear" />
            <Button text="Cancelar"                   press="onCancelCrear" />
        </buttons>
    </Dialog>

</mvc:View>
