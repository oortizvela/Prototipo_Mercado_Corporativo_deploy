<mvc:View
    controllerName="com.claro.compras.portal.controller.requerimiento.InfraOMList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page showHeader="false" enableScrolling="false">
        <content>

            <VBox class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">
                <Title text="Gestión de Solicitud de Requerimientos de Compras" level="H2" />
            </VBox>

            <!-- Filtros (2.2.3) -->
            <Panel expandable="false" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <content>
                    <HBox wrap="Wrap" alignItems="End" class="sapUiSmallMargin">
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Número de Solicitud" labelFor="omFilterNumSol" />
                            <Input id="omFilterNumSol" liveChange="onFilterChange" width="11rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Título" labelFor="omFilterTitulo" />
                            <Input id="omFilterTitulo" liveChange="onFilterChange" width="14rem" />
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Estado" labelFor="omFilterEstado" />
                            <Select id="omFilterEstado" change="onFilterChange" width="12rem">
                                <core:Item key="" text="" />
                                <core:Item key="Registrado"    text="Registrado" />
                                <core:Item key="En Aprobación" text="En Aprobación" />
                                <core:Item key="Aprobado"      text="Aprobado" />
                                <core:Item key="Rechazado"     text="Rechazado" />
                                <core:Item key="Finalizado"    text="Finalizado" />
                            </Select>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Solped" labelFor="omFilterSolped" />
                            <Select id="omFilterSolped" change="onFilterChange" width="12rem">
                                <core:Item key="" text="" />
                                <core:Item key="SOLPED-020" text="SOLPED-020" />
                                <core:Item key="SOLPED-021" text="SOLPED-021" />
                                <core:Item key="2000000001" text="2000000001" />
                            </Select>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Pedido" labelFor="omFilterPedido" />
                            <Select id="omFilterPedido" change="onFilterChange" width="12rem">
                                <core:Item key="" text="" />
                                <core:Item key="4500000001" text="4500000001" />
                                <core:Item key="4500000002" text="4500000002" />
                            </Select>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Tp Solicitud" labelFor="omFilterTipo" />
                            <Select id="omFilterTipo" change="onFilterChange" width="16rem">
                                <core:Item key="" text="" />
                                <core:Item key="Mantenimiento Correctivo"  text="Mantenimiento Correctivo" />
                                <core:Item key="Mantenimiento Preventivo"  text="Mantenimiento Preventivo" />
                                <core:Item key="Reposición Equipos"        text="Reposición Equipos" />
                                <core:Item key="Soporte Operativo"         text="Soporte Operativo" />
                                <core:Item key="Atención Fallas"           text="Atención Fallas" />
                            </Select>
                        </VBox>
                        <Link text="Limpiar Filtros" press="onClearFilters" class="sapUiSmallMarginBegin" />
                    </HBox>
                </content>
            </Panel>

            <!-- Tabla (2.2.1) -->
            <Table
                id="omTable"
                items="{om>/items}"
                growing="true"
                growingThreshold="20"
                noDataText="No se encontraron solicitudes"
                mode="MultiSelect"
                selectionChange="onSelectionChange"
                class="sapUiSmallMarginBeginEnd">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Solicitudes" level="H3" />
                        <ToolbarSpacer />
                        <Button text="+ Crear Solicitud"
                                type="Emphasized"
                                press="onCrearSolicitud" />
                        <Button text="Validación Operativa"
                                icon="sap-icon://technical-object"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onValidacionOperativa" />
                        <Button text="Aprob. Necesidad"
                                icon="sap-icon://approvals"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onAprobNecesidad" />
                        <Button text="Enviar a Compras"
                                icon="sap-icon://paper-plane"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onEnviarCompras" />
                        <Button text="Finalizar Solicitud"
                                icon="sap-icon://task"
                                type="Transparent"
                                enabled="{ui>/haySeleccion}"
                                press="onFinalizar" />
                        <Button text="Exportar Excel"
                                icon="sap-icon://excel-attachment"
                                type="Transparent"
                                press="onExportar" />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="13rem"><Text text="Número de Solicitud" /></Column>
                    <Column><Text text="Título" /></Column>
                    <Column width="16rem"><Text text="Tipo de Solicitud" /></Column>
                    <Column width="14rem"><Text text="Estado" /></Column>
                    <Column width="10rem"><Text text="Solped" /></Column>
                    <Column width="10rem"><Text text="Pedido" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Link text="{om>reqId}" press="onItemPress" />
                            <Text text="{om>titulo}" wrapping="false" />
                            <Text text="{om>tipoSolicitud}" wrapping="false" />
                            <ObjectStatus
                                text="{om>estado}"
                                icon="{= ${om>estado} === 'Rechazado'     ? 'sap-icon://sys-cancel-2' :
                                          ${om>estado} === 'Finalizado'   ? 'sap-icon://sys-enter-2'  :
                                          ${om>estado} === 'Aprobado'     ? 'sap-icon://sys-enter-2'  :
                                          ${om>estado} === 'En Aprobación'? 'sap-icon://sys-help-2'   :
                                          ${om>estado} === 'Registrado'   ? 'sap-icon://create-form'  :
                                                                             'sap-icon://sys-help-2'}"
                                state="{= ${om>estado} === 'Rechazado'     ? 'Error'   :
                                          ${om>estado} === 'Finalizado'    ? 'Success' :
                                          ${om>estado} === 'Aprobado'      ? 'Success' :
                                          ${om>estado} === 'En Aprobación' ? 'Warning' :
                                                                              'None'}" />
                            <Text text="{om>numeroSolped}" />
                            <Text text="{om>numeroPedido}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

        </content>
    </Page>

    <!-- Diálogo Crear Solicitud O&M (2.2.2) -->
    <Dialog
        id="dlgCrearOM"
        title="Crear Solicitud"
        contentWidth="36rem"
        verticalScrolling="false"
        stretch="false"
        class="sapUiContentPadding">
        <content>
            <VBox width="100%">
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="Título:" required="true" labelFor="dlgOmTitulo" />
                    <Input id="dlgOmTitulo"
                           placeholder="Ingrese el título de la solicitud"
                           width="100%" />
                </VBox>
                <VBox>
                    <Label text="Tipo de Solicitud:" required="true" labelFor="dlgOmTipo" />
                    <Select id="dlgOmTipo" width="100%">
                        <core:Item key="Mantenimiento Correctivo" text="Mantenimiento Correctivo" />
                        <core:Item key="Mantenimiento Preventivo" text="Mantenimiento Preventivo" />
                        <core:Item key="Reposición Equipos"       text="Reposición Equipos" />
                        <core:Item key="Soporte Operativo"        text="Soporte Operativo" />
                        <core:Item key="Atención Fallas"          text="Atención Fallas" />
                    </Select>
                </VBox>
            </VBox>
        </content>
        <buttons>
            <Button text="Crear"    type="Emphasized" press="onConfirmCrear" />
            <Button text="Cancelar"                   press="onCancelCrear" />
        </buttons>
    </Dialog>

</mvc:View>
