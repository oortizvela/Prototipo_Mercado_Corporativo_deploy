<mvc:View
    controllerName="com.claro.compras.portal.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true">

    <Page showHeader="false" class="loginPage">
        <content>

            <!-- Fondo gris claro -->
            <VBox height="100%" justifyContent="Center" alignItems="Center" class="loginBackground">

                <!-- Tarjeta de login -->
                <VBox class="loginCard">

                    <!-- Logo SAP -->
                    <core:HTML content="&lt;div class='loginSapLogo'&gt;&lt;span&gt;SAP&lt;/span&gt;&lt;/div&gt;" />

                    <!-- Título -->
                    <Title text="Iniciar sesión" level="H2" class="loginTitle" />
                    <Text text="SAP Build Work Zone, standard edition (pc-dev)" class="loginSubtitle" />

                    <!-- Spacer -->
                    <core:HTML content="&lt;div style='height:1.5rem'&gt;&lt;/div&gt;" />

                    <!-- Campo usuario -->
                    <VBox class="loginFieldRow">
                        <Label text="Correo electrónico o nombre de usuario" labelFor="inputUsuario" class="loginLabel" />
                        <Input
                            id="inputUsuario"
                            placeholder="Correo electrónico o nombre de usuario"
                            width="100%"
                            class="loginInput"
                            submit="onLogin" />
                    </VBox>

                    <!-- Campo contraseña -->
                    <VBox class="loginFieldRow">
                        <Label text="Contraseña" labelFor="inputPassword" class="loginLabel" />
                        <Input
                            id="inputPassword"
                            placeholder="Contraseña"
                            type="Password"
                            width="100%"
                            class="loginInput"
                            submit="onLogin" />
                    </VBox>

                    <!-- Mantener sesión + Olvidó contraseña -->
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="loginCheckRow">
                        <CheckBox id="chkMantenerSesion" text="Mantener inicio de sesión" />
                        <Link text="¿Ha olvidado la contraseña?" href="#" subtle="true" />
                    </HBox>

                    <!-- Mensaje de error -->
                    <Text
                        id="txtLoginError"
                        text="Usuario o contraseña incorrectos"
                        visible="false"
                        class="loginErrorText" />

                    <!-- Botón Continuar -->
                    <Button
                        text="Continuar"
                        type="Emphasized"
                        width="100%"
                        press="onLogin"
                        class="loginBtn" />

                </VBox>

                <!-- Botón para abrir tabla de usuarios demo -->
                <Button
                    text="Usuarios de referencia (prototipo)"
                    icon="sap-icon://group"
                    type="Transparent"
                    class="sapUiSmallMarginTop"
                    press="onOpenDemoUsers" />

            </VBox>

        </content>
    </Page>

    <!-- Dialog con tabla de usuarios demo -->
    <Dialog
        id="dlgDemoUsers"
        title="Usuarios de referencia (prototipo)"
        contentWidth="62rem"
        contentHeight="auto"
        resizable="false"
        draggable="true">
        <content>
            <Table
                id="tblDemoUsers"
                items="{demoUsers>/users}"
                showSeparators="Inner"
                backgroundDesign="Transparent"
                fixedLayout="false">
                <columns>
                    <Column width="9rem"><Text text="Usuario" wrapping="false" /></Column>
                    <Column width="7rem"><Text text="Contrase&#xF1;a" wrapping="false" /></Column>
                    <Column width="12rem"><Text text="Nombre" wrapping="false" /></Column>
                    <Column><Text text="Rol / Canal que aprueba" wrapping="false" /></Column>
                    <Column width="9rem" hAlign="End"><Text text="" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{demoUsers>usuario}" wrapping="false" />
                            <Text text="{demoUsers>password}" wrapping="false" />
                            <Text text="{demoUsers>nombre}" wrapping="false" />
                            <Text text="{demoUsers>rol}" wrapping="true" />
                            <Button
                                text="Iniciar sesi&#xF3;n"
                                type="Emphasized"
                                icon="sap-icon://log"
                                press="onQuickLogin" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button text="Cerrar" press="onCloseDemoUsers" />
        </endButton>
    </Dialog>

</mvc:View>
